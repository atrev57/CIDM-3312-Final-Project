@page
@model IndexModel

@{
    ViewData["Title"] = "Books";
}

<!-- Search From -->
<form method="get" class="mb-4">
    <div class="input-group">
        <input type="text" asp-for="CurrentSearch" class="form-control" placeholder="Search by title or author..." />
        <button class="btn btn-primary" type="submit">Search</button>
        <a asp-page="./Index" class="btn btn-secondary">Clear</a>
    </div>
</form>

<!-- Sorting Links -->
<div class="mb-3">
    <strong>Sort By: </strong>
    <a asp-page="./Index" asp-route-CurrentSort="title_asc" asp-route-CurrentSearch="@Model.CurrentSearch" class="btn btn-sm btn-outline-secondary">Title A-Z</a>
    <a asp-page="./Index" asp-route-CurrentSort="title_desc" asp-route-CurrentSearch="@Model.CurrentSearch" class="btn btn-sm btn-outline-secondary">Title Z-A</a>
    |
    <a asp-page="./Index" asp-route-CurrentSort="author_asc" asp-route-CurrentSearch="@Model.CurrentSearch" class="btn btn-sm btn-outline-secondary">Author A-Z</a>
    <a asp-page="./Index" asp-route-CurrentSort="author_desc" asp-route-CurrentSearch="@Model.CurrentSearch" class="btn btn-sm btn-outline-secondary">Author Z-A</a>
</div>

<hr />

@foreach (var b in Model.Books)
{
    // Get all reviews for this book
    var reviews = b.BookReviews.Select(br => br.Review).ToList();

    double reviewAvg = reviews.Any()
        ? (double)reviews.Average(r => r.Score)
        : 0;

    int reviewCnt = reviews.Count;

    // First review shown immediately
    var firstReview = reviews.FirstOrDefault();

    // Remaining reviews hidden in collapse
    var extraReviews = reviews.Skip(1);

    <div class="row mb-4">
        
        <!-- Book Cover -->
        <div class="col-2">
            <img src="@b.ImageURL" class="img-fluid rounded">
        </div>

        <!-- Book Info -->
        <div class="col-10">
            <h3>@b.Title</h3>
            <p class="text-muted">@b.Author</p>

            <!-- Average Rating -->
            <p>
                <span>@reviewAvg.ToString("0.0")</span>
                @for (int i = 1; i <= 5; i++)
                {
                    if (reviewAvg >= i)
                    {
                        <i class="bi bi-star-fill text-warning"></i>
                    }
                    else if (reviewAvg > i - 1)
                    {
                        <i class="bi bi-star-half text-warning"></i>
                    }
                    else
                    {
                        <i class="bi bi-star"></i>
                    }
                }
                <span>(@reviewCnt reviews)</span>
            </p>

            <!-- First Review -->
            @if (firstReview != null)
            {
                <div class="border rounded p-2 mb-2">
                    <!-- Review Stars -->
                    @for (int i = 1; i <= 5; i++)
                    {
                        if (firstReview.Score >= i)
                        {
                            <i class="bi bi-star-fill text-warning"></i>
                        }
                        else
                        {
                            <i class="bi bi-star"></i>
                        }
                    }
                    <p class="mb-0 mt-1">
                        @firstReview.ReviewText
                    </p>
                </div>
            }

            <!-- Collapse Button -->
            @if (reviewCnt > 1)
            {
                <button class="btn btn-primary btn-sm"
                        type="button"
                        data-bs-toggle="collapse"
                        data-bs-target="#reviews@(b.BookID)">
                    Show More Reviews
                </button>
                
                <!-- Hidden Reviews -->
                <div class="collapse mt-2" id="reviews@(b.BookID)">
                    @foreach (var r in extraReviews)
                    {
                        <div class="border rounded p-2 mb-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                if (r.Score >= i)
                                {
                                    <i class="bi bi-star-fill text-warning"></i>
                                }
                                else
                                {
                                    <i class="bi bi-star"></i>
                                }
                            }
                            <p class="mb-0 mt-1">
                                @r.ReviewText
                            </p>
                        </div>
                    }
                </div>
            }
        </div>
    </div>
    <hr />
}

<!--Pagination Controls -->
<nav aria-label="Page navigation">
    <ul class="pagination justify-content-center">
        <!-- Previous Button -->
        <li class="page-item @(Model.PageNum <= 1 ? "disabled" : "")">
            <a class="page-link" asp-page="./Index" 
               asp-route-PageNum="@(Model.PageNum - 1)" 
               asp-route-CurrentSearch="@Model.CurrentSearch" 
               asp-route-CurrentSort="@Model.CurrentSort">Previous</a>
        </li>

        <!-- Page Numbers -->
        @for (int i = 1; i <= Model.TotalPages; i++)
        {
            <li class="page-item @(i == Model.PageNum ? "active" : "")">
                <a class="page-link" asp-page="./Index" 
                   asp-route-PageNum="@i" 
                   asp-route-CurrentSearch="@Model.CurrentSearch" 
                   asp-route-CurrentSort="@Model.CurrentSort">@i</a>
            </li>
        }

        <!-- Next Button -->
        <li class="page-item @(Model.PageNum >= Model.TotalPages ? "disabled" : "")">
            <a class="page-link" asp-page="./Index" 
               asp-route-PageNum="@(Model.PageNum + 1)" 
               asp-route-CurrentSearch="@Model.CurrentSearch" 
               asp-route-CurrentSort="@Model.CurrentSort">Next</a>
        </li>
    </ul>
</nav>