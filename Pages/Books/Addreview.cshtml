@page
@model CIDM_3312_Final_Project.Pages_Books.AddReviewModel

@{
    ViewData["Title"] = "Add Book Review";
}

<h1>Share A Thought!</h1>

<h4>Book Review</h4>
<hr />

<form method="post">

    <!-- Book Selection -->
    <div class="row mb-3">
        <div class="col-4">
            <label asp-for="SelectedBookID" class="control-label">Book</label>

            <select asp-for="SelectedBookID"
                    asp-items="Model.BooksDropDown"
                    class="form-select">
                <option value="">Choose A Book To Review</option>
            </select>

            <span asp-validation-for="SelectedBookID" class="text-danger"></span>
        </div>
    </div>

    <!-- Score -->
    <div class="row mb-3">
        <div class="col-4">
            <label asp-for="Review.Score" class="form-label"></label>

            <input asp-for="Review.Score" class="form-control" />

            <span asp-validation-for="Review.Score" class="text-danger"></span>
        </div>
    </div>

    <!-- Review Text -->
    <div class="row mb-3">
        <div class="col-4">
            <label asp-for="Review.ReviewText" class="form-label"></label>

            <textarea asp-for="Review.ReviewText" class="form-control"></textarea>

            <span asp-validation-for="Review.ReviewText" class="text-danger"></span>
        </div>
    </div>

    <button type="submit" class="btn btn-primary">Submit</button>

</form>

<div class="mt-3">
    <a asp-page="/Index">Back to List</a>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}